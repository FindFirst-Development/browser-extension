{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["chrome", "firefox-webext-browser"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
