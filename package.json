{
  "name": "findfirst-browser-extensions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:chrome": "node build.js --target=chrome",
    "build:firefox": "node build.js --target=firefox",
    "dev:chrome": "node build.js --target=chrome --watch",
    "dev:firefox": "node build.js --target=firefox --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.321",
    "@types/firefox-webext-browser": "^120.0.2",
    "@types/jsdom": "^28.0.3",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "web-ext": "^8.4.0"
  }
}
